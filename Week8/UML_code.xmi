    <codegeneration>
      <codegenerator language="Python">
        <sourcecode id="uNtFXaBW8KWiR" value="self.total_space=total_space&#10;self.used_space=0&#10;self.plants=[]&#10;self.animals=[]&#10;self.round_counter=0&#10;self.season=&quot;Spring&quot;&#10;self.weather_factor=1.0&#10;"/>
        <sourcecode id="u9kwrTSdEtejA" value="if plant.needs_ground:&#10;  if self.used_space+plant.space_needed&lt;=self.total_space:&#10;    self.plants.append(plant)&#10;    self.used_space+=plant.space_needed&#10;    return True&#10;&#10;  return False&#10;&#10;"/>
        <sourcecode id="uulqdjTBBSHUC" value="if plant in self.plants:&#10;  self.plants.remove(plant)&#10;  if plant.needs_ground:&#10;    self.used_space-=plant.space_needed&#10;&#10;&#10;"/>
        <sourcecode id="uMrhK8gvwqI41" value="if animal in self.animals:&#10;  self.animals.remove(animal)&#10;&#10;"/>
        <sourcecode id="uCV976gqoQhW3" value="seasons=[&quot;Spring&quot;,&quot;Summer&quot;,&quot;Autumn&quot;,&quot;Winter&quot;]&#10;if self.round_counter&gt;0 and self.round_counter%10==0:&#10;  current_idx=seasons.index(self.season)&#10;  self.season=seasons[(current_idx+1)%4]&#10;  factors={&#10;  &quot;Spring&quot;:1.1,&quot;Summer&quot;:1.3,&#10;  &quot;Autumn&quot;:0.9,&quot;Winter&quot;:0.6}&#10;  self.weather_factor=factors[self.season]&#10;&#10;"/>
        <sourcecode id="usLVAo0wALgqo" value="if self.used_space&gt;self.total_space*0.9:&#10;  ground_plants=[p for p in self.plants if p.needs_ground]&#10;  if ground_plants:&#10;    ground_plants.sort(key=lambda p:p.current_size)&#10;    num_to_remove=max(1,len(ground_plants)//10)&#10;    for i in range(num_to_remove):&#10;      plant=ground_plants[i]&#10;      plant.die()&#10;      self.remove_plant(plant)&#10;&#10;&#10;&#10;"/>
        <sourcecode id="u4aFGsDVVsHNw" value="self.round_counter+=1&#10;self.change_season()&#10;self.check_space_competition()&#10;for plant in self.plants[:]:&#10;  result=plant.grow(self.weather_factor)&#10;  if not plant.is_alive:&#10;    self.remove_plant(plant)&#10;    continue&#10;&#10;  if isinstance(result,Apple):&#10;    self.add_plant(result)&#10;&#10;  if plant.can_reproduce()and random.random()&lt;0.2:&#10;    offspring=type(plant)(f&quot;{plant.name}_child&quot;)&#10;    self.add_plant(offspring)&#10;&#10;&#10;for animal in self.animals[:]:&#10;  if animal.is_alive:&#10;    if isinstance(animal,Bear):&#10;      animal.prepare_hibernation(self.season)&#10;&#10;    animal.grow()&#10;    if animal.age&gt;animal.max_age:&#10;      print(f&quot;{animal.name} died of old age.&quot;)&#10;      animal.is_alive=False&#10;&#10;    else:&#10;      animal.eat(self)&#10;&#10;    if animal.is_alive and animal.can_reproduce():&#10;      offspring=type(animal)(f&quot;{animal.name}_baby&quot;)&#10;      self.animals.append(offspring)&#10;&#10;    if animal.check_starvation():&#10;      if animal in self.animals:&#10;        self.animals.remove(animal)&#10;&#10;&#10;&#10;  else:&#10;    if animal in self.animals:&#10;      self.animals.remove(animal)&#10;&#10;&#10;&#10;"/>
        <sourcecode id="uNptNnXAOb25M" value="self.name=name&#10;self.age=0&#10;self.is_alive=True&#10;"/>
        <sourcecode id="uGwOyFMSDn1T2" value="pass&#10;"/>
        <sourcecode id="umxYh4orZhsvK" value="self.is_alive=False&#10;"/>
        <sourcecode id="u76hGoDbf6Ap0" value="pass&#10;"/>
        <sourcecode id="uHnoShQnhke5Y" value="super().__init__(name)&#10;self.min_size=min_size&#10;self.max_size=max_size&#10;self.current_size=min_size&#10;self.growth_rate=growth_rate&#10;self.space_needed=space_needed&#10;self.needs_ground=needs_ground&#10;self.reproduction_interval=reproduction_interval&#10;self.rounds_since_reproduction=0&#10;self.max_age=50&#10;"/>
        <sourcecode id="uR9FOxtempmQD" value="if not self.is_alive:&#10;  return 0&#10;&#10;growth=int(self.growth_rate*weather_factor*&#10;random.uniform(0.7,1.3))new_size=min(self.current_size+growth,self.max_size)&#10;actual_growth=new_size-self.current_size&#10;self.current_size=new_size&#10;self.age+=1&#10;if self.age&gt;self.max_age:&#10;  self.is_alive=False&#10;  print(f&quot;{self.name} has withered away due to old age.&quot;)&#10;&#10;return actual_growth&#10;"/>
        <sourcecode id="uqaQlJKCpNhZC" value="self.current_size-=amount&#10;if self.current_size&lt;self.min_size:&#10;  self.die()&#10;  return False&#10;&#10;return True&#10;"/>
        <sourcecode id="uPrZbipBbF9fx" value="if self.rounds_since_reproduction&lt;self.reproduction_interval:&#10;  self.rounds_since_reproduction+=1&#10;  return False&#10;&#10;can_repro=(self.current_size&gt;=self.max_size*0.8 and self.age&gt;3)&#10;if can_repro:&#10;  self.rounds_since_reproduction=0&#10;&#10;return can_repro&#10;"/>
        <sourcecode id="u3LJaIGwaYL4b" value="status=&quot;alive&quot;if self.is_alive else&quot;dead&quot;&#10;return(f&quot;{self.name} (Plant): Size {self.current_size}/&quot;&#10;f&quot;{self.max_size}, Age {self.age}, {status}&quot;)"/>
        <sourcecode id="uBemO329PIY93" value="super().__init__(name,min_size=10,max_size=100,&#10;growth_rate=1,space_needed=15,needs_ground=True,reproduction_interval=10)"/>
        <sourcecode id="uhrsD38Ac2O4l" value="super().__init__(name,min_size=2,max_size=10,&#10;growth_rate=4,space_needed=3,needs_ground=True,reproduction_interval=3)self.drought_resistance=random.randint(3,7)&#10;"/>
        <sourcecode id="ujChJ6njNlk3j" value="super().__init__(name,min_size=8,max_size=60,&#10;growth_rate=2,space_needed=12,needs_ground=True,reproduction_interval=7)"/>
        <sourcecode id="u7pTY8R5EYbQl" value="super().__init__(name,min_size=1,max_size=5,growth_rate=0,&#10;space_needed=0,needs_ground=True,reproduction_interval=999)self.current_size=5&#10;self.max_age=3&#10;"/>
        <sourcecode id="uq5NuAzcIg0Jd" value="super().__init__(name)&#10;self.hunger=0&#10;self.max_hunger=max_hunger&#10;self.strength=strength&#10;self.hibernating=False&#10;self.feeding_interval=feeding_interval&#10;self.rounds_since_eating=0&#10;self.max_age=50&#10;self.metabolic_rate=1.0/self.feeding_interval&#10;self.hibernation_bonus=2&#10;self.repro_cooldown=0&#10;self.cooldown_duration=5&#10;self.min_repro_age=4&#10;self.hunger_threshold=5&#10;"/>
        <sourcecode id="uOAVgaSYfAz9O" value="pass&#10;"/>
        <sourcecode id="uQqOsweQnRZNg" value="if self.hunger&gt;=self.max_hunger:&#10;  self.die()&#10;  return True&#10;&#10;return False&#10;"/>
        <sourcecode id="uZWcMFY5tOhMz" value="self.hibernating=True&#10;self.hunger=max(0,self.hunger-self.hibernation_bonus)&#10;"/>
        <sourcecode id="uhlFL4g02lwAQ" value="self.hibernating=False&#10;"/>
        <sourcecode id="uohpJLBw38NyX" value="self.age+=1&#10;if not self.hibernating:&#10;  self.hunger+=self.metabolic_rate&#10;  self.rounds_since_eating+=1&#10;&#10;"/>
        <sourcecode id="u3wSlRO9C7BaG" value="if self.repro_cooldown&gt;0:&#10;  self.repro_cooldown-=1&#10;  return False&#10;&#10;is_ready=(&#10;self.age&gt;self.min_repro_age and self.hunger&lt;self.hunger_threshold)&#10;if is_ready:&#10;  self.repro_cooldown=self.cooldown_duration&#10;  return True&#10;&#10;return False&#10;"/>
        <sourcecode id="uEm713WnFgv57" value="if self.age&gt;self.max_age:&#10;  self.is_alive=False&#10;  return True&#10;&#10;return False&#10;"/>
        <sourcecode id="u3KId3Cjg0rL5" value="is_unable_to_eat=self.hibernating&#10;is_still_full=self.rounds_since_eating&lt;self.feeding_interval&#10;if is_unable_to_eat or is_still_full:&#10;  return False&#10;&#10;edible_plants=[p for p in habitat.plants if p.is_alive]&#10;if edible_plants:&#10;  plant=random.choice(edible_plants)&#10;  eat_amount=random.randint(1,4)&#10;  if plant.be_eaten(eat_amount):&#10;    self.hunger=max(0,self.hunger-eat_amount)&#10;    self.rounds_since_eating=0&#10;    return True&#10;&#10;  else:&#10;    habitat.remove_plant(plant)&#10;    self.hunger=max(0,self.hunger-eat_amount)&#10;    self.rounds_since_eating=0&#10;    return True&#10;&#10;&#10;return False&#10;"/>
        <sourcecode id="uNCpisua1IVev" value="super().__init__(name,max_hunger,strength,feeding_interval)&#10;self.hunt_skill=random.randint(5,10)&#10;self.meat_reward=5&#10;"/>
        <sourcecode id="uRtBQZdfqym9Z" value="is_sleeping=self.hibernating&#10;is_not_hungry_yet=self.rounds_since_eating&lt;self.feeding_interval&#10;if is_sleeping or is_not_hungry_yet:&#10;  return False&#10;&#10;prey_list=[]&#10;for animal in habitat.animals:&#10;  is_alive=animal.is_alive&#10;  is_not_me=animal!=self&#10;  is_not_carnivore=not isinstance(animal,Carnivore)&#10;  if is_alive and is_not_me and is_not_carnivore:&#10;    species_count=len([a for a in habitat.animals&#10;    if isinstance(a,type(animal))and a.is_alive])if species_count&gt;3:&#10;      prey_list.append(animal)&#10;&#10;&#10;&#10;if not prey_list:&#10;  return False&#10;&#10;prey=random.choice(prey_list)&#10;success_chance=(self.hunt_skill+self.strength)/20&#10;modifiers={&#10;&quot;Winter&quot;:0.8,&quot;Spring&quot;:1.1,&#10;&quot;Summer&quot;:1.05,&quot;Autumn&quot;:1.0}&#10;success_chance*=modifiers.get(habitat.season,1.0)&#10;if random.random()&lt;success_chance:&#10;  prey.die()&#10;  habitat.remove_animal(prey)&#10;  self.hunger=max(0,self.hunger-self.meat_reward)&#10;  self.rounds_since_eating=0&#10;  return True&#10;&#10;return False&#10;"/>
        <sourcecode id="ub3QcXLkeDGPE" value="super().__init__(name,max_hunger,strength,feeding_interval)&#10;self.plant_bite_size=2&#10;self.meat_reward=5&#10;"/>
        <sourcecode id="uVhBWKDXYDElV" value="is_sleeping=self.hibernating&#10;is_still_full=self.rounds_since_eating&lt;self.feeding_interval&#10;if is_sleeping or is_still_full:&#10;  return False&#10;&#10;is_very_hungry=self.hunger&gt;(self.max_hunger*0.7)&#10;if is_very_hungry:&#10;  potential_prey=[]&#10;  for animal in habitat.animals:&#10;    is_alive=animal.is_alive&#10;    is_not_self=animal!=self&#10;    is_weaker=animal.strength&lt;self.strength&#10;    if is_alive and is_not_self and is_weaker:&#10;      potential_prey.append(animal)&#10;&#10;&#10;  if potential_prey:&#10;    target=random.choice(potential_prey)&#10;    target.die()&#10;    habitat.remove_animal(target)&#10;    self.hunger=max(0,self.hunger-self.meat_reward)&#10;    self.rounds_since_eating=0&#10;    return True&#10;&#10;&#10;else:&#10;  plant_list=[p for p in habitat.plants if p.is_alive]&#10;  if plant_list:&#10;    plant=random.choice(plant_list)&#10;    plant.be_eaten(self.plant_bite_size)&#10;    self.hunger=max(0,self.hunger-self.plant_bite_size)&#10;    self.rounds_since_eating=0&#10;    return True&#10;&#10;&#10;return False&#10;"/>
        <sourcecode id="uxuZZIQJYAxDo" value="super().__init__(name,max_hunger=6,strength=2,feeding_interval=1)&#10;self.repro_cooldown=0&#10;self.cooldown_duration=3&#10;self.min_repro_age=2&#10;self.hunger_threshold=4&#10;"/>
        <sourcecode id="uBsSCErLOSwav" value="if self.repro_cooldown&gt;0:&#10;  self.repro_cooldown-=1&#10;  return False&#10;&#10;is_ready=(&#10;self.age&gt;self.min_repro_age and self.hunger&lt;self.hunger_threshold)&#10;if is_ready:&#10;  self.repro_cooldown=self.cooldown_duration&#10;  return True&#10;&#10;return False&#10;"/>
        <sourcecode id="unfKxHC1PLZph" value="super().__init__(name,max_hunger=8,strength=3,feeding_interval=2)&#10;"/>
        <sourcecode id="ucNcSUmy8cXvV" value="eucs=[p for p in habitat.plants&#10;if isinstance(p,Eucalyptus)and p.is_alive]if eucs:&#10;  if eucs:&#10;    plant=random.choice(eucs)&#10;    eat_amount=2&#10;&#10;  if plant.be_eaten(eat_amount):&#10;    self.hunger=max(0,self.hunger-eat_amount)&#10;    self.rounds_since_eating=0&#10;    return True&#10;&#10;&#10;return False&#10;"/>
