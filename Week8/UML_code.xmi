        <ownedAttribute xmi:type="uml:Property" xmi:id="uqbgZGUyXdTJG" name="repro_cooldown" comment="Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round Logic: Named constant for metabolic energy saved during hibernation. This makes it easy to adjust the survival bonus in one central place. Reproduction attributes Current timer (starts at 0) Rounds to wait after having a baby Age needed to be mature enough Maximum hunger allowed to reproduce Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round Logic: Named constant for metabolic energy saved during hibernation. This makes it easy to adjust the survival bonus in one central place. Reproduction attributes Current timer (starts at 0)" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uA91tTIEIkJJ3" name="cooldown_duration" comment="Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round Logic: Named constant for metabolic energy saved during hibernation. This makes it easy to adjust the survival bonus in one central place. Reproduction attributes Current timer (starts at 0) Rounds to wait after having a baby Age needed to be mature enough Maximum hunger allowed to reproduce Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round Logic: Named constant for metabolic energy saved during hibernation. This makes it easy to adjust the survival bonus in one central place. Reproduction attributes Current timer (starts at 0) Rounds to wait after having a baby" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="umKAm0ns2jdUQ" name="min_repro_age" comment="Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round Logic: Named constant for metabolic energy saved during hibernation. This makes it easy to adjust the survival bonus in one central place. Reproduction attributes Current timer (starts at 0) Rounds to wait after having a baby Age needed to be mature enough Maximum hunger allowed to reproduce Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round Logic: Named constant for metabolic energy saved during hibernation. This makes it easy to adjust the survival bonus in one central place. Reproduction attributes Current timer (starts at 0) Rounds to wait after having a baby Age needed to be mature enough" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="ulwx2jmpQ48We" name="hunger_threshold" comment="Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round Logic: Named constant for metabolic energy saved during hibernation. This makes it easy to adjust the survival bonus in one central place. Reproduction attributes Current timer (starts at 0) Rounds to wait after having a baby Age needed to be mature enough Maximum hunger allowed to reproduce Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round Logic: Named constant for metabolic energy saved during hibernation. This makes it easy to adjust the survival bonus in one central place. Reproduction attributes Current timer (starts at 0) Rounds to wait after having a baby Age needed to be mature enough Maximum hunger allowed to reproduce" type="uyDey6iEor2tQ"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uq5NuAzcIg0Jd" name="__init__" comment="Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round Logic: Named constant for metabolic energy saved during hibernation. This makes it easy to adjust the survival bonus in one central place. Reproduction attributes Current timer (starts at 0) Rounds to wait after having a baby Age needed to be mature enough Maximum hunger allowed to reproduce" stereotype="constructor">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uKuYH9EJ1d2aP" name="name, hunger, ..." visibility="private" type="" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uOAVgaSYfAz9O" name="eat" isAbstract="true" comment="Each animal type has a different way of finding food.">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uGBlSg84pAoQa" name="habitat" visibility="private" type="u9OmGItKhHptN" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uQqOsweQnRZNg" name="check_starvation" comment="Kills the animal if it hasn't eaten enough.">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="ucFkbHlWWS7dj" type="uuZvRER5voAkM" direction="return"/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uZWcMFY5tOhMz" name="enter_hibernation" comment="Logic: Reduce hunger by the defined bonus to simulate slower metabolism"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uhlFL4g02lwAQ" name="wake_up" comment="Wakes the animal from hibernation."/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uohpJLBw38NyX" name="grow" comment="Increments age and calculates hunger increase based on metabolism.&#10;Logic: We use the precalculated rate dependend on size/interval. This ensure consistent hunger growth."/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="u3wSlRO9C7BaG" name="can_reproduce" comment="Standard reproduction logic for all animals.">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uETYClhkjgb0f" type="uuZvRER5voAkM" direction="return"/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uEm713WnFgv57" name="check_aging" comment="Died of old age">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uO0LHcHUfW437" type="uuZvRER5voAkM" direction="return"/>
        </ownedOperation>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="umsFRoR96XmpJ" name="Herbivore" comment="    Eats plants. Found in the habitat's plant list.&#10;    &gt;&gt;&gt; # Testing the basic attributes of a Herbivore using a Rabbit&#10;    &gt;&gt;&gt; h = Rabbit(&quot;Thumper&quot;)&#10;    &gt;&gt;&gt; h.strength&#10;    2&#10;    &gt;&gt;&gt; # Most small herbivores have a feeding_interval of 1&#10;    &gt;&gt;&gt; h.metabolic_rate&#10;    1.0&#10;    &gt;&gt;&gt; h.hunger&#10;    0.0&#10;    &gt;&gt;&gt; h.grow()&#10;    &gt;&gt;&gt; h.hunger&#10;    1.0&#10;">
        <generalization xmi:type="uml:Generalization" xmi:id="uQ3loIF3nHHAs" general="uhh5q2NtgxacK"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="u3KId3Cjg0rL5" name="eat" comment="We store conditions in descriptive variables for better readability Early Exit: If the animal is asleep or not hungry yet, we stop here Search for any edible plant in the environment 'p' is our placeholder for each plant in the list Try to eat the plant Plant died from overgrazing, remove it">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uFm9qL7klLBSG" type="uuZvRER5voAkM" direction="return"/>
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uwi5Z8R1hiuaU" name="habitat" visibility="private" type="u9OmGItKhHptN" value=""/>
        </ownedOperation>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="uafw02rT0a2uW" name="Carnivore" comment="    Hunts other animals.&#10;    &gt;&gt;&gt; # Testing the basic attributes of a Carnivore&#10;    &gt;&gt;&gt; c = Wolf(&quot;Isegrim&quot;)&#10;    &gt;&gt;&gt; c.strength&#10;    10&#10;    &gt;&gt;&gt; # Carnivores typically have a feeding_interval of 2&#10;    &gt;&gt;&gt; c.metabolic_rate&#10;    0.5&#10;    &gt;&gt;&gt; c.hunger&#10;    0.0&#10;    &gt;&gt;&gt; c.grow()&#10;    &gt;&gt;&gt; c.hunger&#10;    0.5&#10;">
        <generalization xmi:type="uml:Generalization" xmi:id="uTq51TWE4Imhc" general="uhh5q2NtgxacK"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uqJORZDA0K6EG" name="hunt_skill" comment="Individual hunting ability Hunger reduction per successful hunt Individual hunting ability" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uutUo5uKGwSsr" name="meat_reward" comment="Individual hunting ability Hunger reduction per successful hunt Individual hunting ability Hunger reduction per successful hunt" type="uyDey6iEor2tQ"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uNCpisua1IVev" name="__init__" comment="Individual hunting ability Hunger reduction per successful hunt" stereotype="constructor">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="um3GKSLgyLkrN" name="name, max_hunger, ..." visibility="private" type="" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uRtBQZdfqym9Z" name="eat" comment="If the carnivore is asleep or still full, it won't hunt Look for prey (any living animal that isn't a carnivore) Ensure population control: only hunt if more than 3 of the Ensure there's enough of the species Safety Check: If no prey is found, stop here (prevents IndexError) RANDOMIZED ASPECT: Seasonal hunting success Seasons modify how easy it is to find prey Animal is consumed">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="ukiFPnGp5sxzL" type="uuZvRER5voAkM" direction="return"/>
          <ownedParameter xmi:type="uml:Parameter" xmi:id="u0RAWszpStMAx" name="habitat" visibility="private" type="u9OmGItKhHptN" value=""/>
        </ownedOperation>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="uMbfO8fDCs326" name="random"/>
      <packagedElement xmi:type="uml:Class" xmi:id="u3ZGSLOnkH7bk" name="Omnivore" comment="&quot;&quot;&#10;    Omnivore - A flexible eater that chooses between plants and meat&#10;    based on its current hunger level.&#10;    &gt;&gt;&gt; # Example using a Bear as a concrete Omnivore&#10;    &gt;&gt;&gt; b = Bear(&quot;Baloo&quot;)&#10;    &gt;&gt;&gt; b.metabolic_rate # Interval 3 -&gt; 0.33 hunger per round&#10;    0.33&#10;    &gt;&gt;&gt; b.hunger = 0.0&#10;    &gt;&gt;&gt; b.grow()&#10;    &gt;&gt;&gt; round(b.hunger, 2)&#10;    0.33&#10;    &gt;&gt;&gt; b.strength&#10;    10&#10;">
        <generalization xmi:type="uml:Generalization" xmi:id="ujJnrPhm3hU0s" general="uhh5q2NtgxacK"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="u31fl7FfTb7sy" name="plant_bite_size" comment="Define the bite size once for the whole class Define the bite size once for the whole class" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uNGbkaqXrQ3G5" name="meat_reward" comment="Define the bite size once for the whole class Define the bite size once for the whole class" type="uyDey6iEor2tQ"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="ub3QcXLkeDGPE" name="__init__" comment="Define the bite size once for the whole class" stereotype="constructor">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="ubZOEkr6zJTxd" name="name, max_hunger, ..." visibility="private" type="" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uVhBWKDXYDElV" name="eat" comment="Early Exit: If the animal shouldn't eat, stop here Logic: If very hungry, try to hunt (more calories). Else, eat plants. Hunting logic (similar to Carnivore) Criteria: must be alive, cannot be itself, and must be weaker The hunt is only possible if all criteria are met Select a random food source from the available plants Interaction: Reduce plant size by the omnivore's specific bite size Update animal stats: decrease hunger and reset the feeding timer Return False if no food was found or if the animal chose not to eat --- Specialized Animal Classes ---">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="u4WDJlUwq4CUt" type="uuZvRER5voAkM" direction="return"/>
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uVZe6csYAAViu" name="habitat" visibility="private" type="u9OmGItKhHptN" value=""/>
        </ownedOperation>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="uOtFfLoVmvbBb" name="Rabbit" comment="    SPECIAL RULE: Fast metabolism, reproduces quickly.&#10;    &gt;&gt;&gt; r = Rabbit(&quot;Bugs&quot;)&#10;    &gt;&gt;&gt; r.hunger&#10;    0.0&#10;    &gt;&gt;&gt; r.metabolic_rate&#10;    1.0&#10;    &gt;&gt;&gt; r.grow() # After one round, hunger should be 1.0&#10;    &gt;&gt;&gt; r.hunger&#10;    1.0&#10;    &gt;&gt;&gt; r.max_hunger&#10;    6&#10;    &gt;&gt;&gt; r.cooldown_duration # Quick reproduction cycle&#10;    3&#10;">
        <generalization xmi:type="uml:Generalization" xmi:id="umar3blXUizGB" general="umsFRoR96XmpJ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uJRC4EAI9GKAk" name="repro_cooldown" comment="These attributes define the reproduction strategy of the rabbit. We override the defaults from the Animal base class. Rounds to wait after having babies Age needed to reach sexual maturity Maximum hunger allowed to reproduce These attributes define the reproduction strategy of the rabbit. We override the defaults from the Animal base class." type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uLj9M7F8cQGZA" name="cooldown_duration" comment="These attributes define the reproduction strategy of the rabbit. We override the defaults from the Animal base class. Rounds to wait after having babies Age needed to reach sexual maturity Maximum hunger allowed to reproduce These attributes define the reproduction strategy of the rabbit. We override the defaults from the Animal base class. Rounds to wait after having babies" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uVkABQhbnqdXS" name="min_repro_age" comment="These attributes define the reproduction strategy of the rabbit. We override the defaults from the Animal base class. Rounds to wait after having babies Age needed to reach sexual maturity Maximum hunger allowed to reproduce These attributes define the reproduction strategy of the rabbit. We override the defaults from the Animal base class. Rounds to wait after having babies Age needed to reach sexual maturity" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="u2RXZxfEOYD9v" name="hunger_threshold" comment="These attributes define the reproduction strategy of the rabbit. We override the defaults from the Animal base class. Rounds to wait after having babies Age needed to reach sexual maturity Maximum hunger allowed to reproduce These attributes define the reproduction strategy of the rabbit. We override the defaults from the Animal base class. Rounds to wait after having babies Age needed to reach sexual maturity Maximum hunger allowed to reproduce" type="uyDey6iEor2tQ"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uxuZZIQJYAxDo" name="__init__" comment="These attributes define the reproduction strategy of the rabbit. We override the defaults from the Animal base class. Rounds to wait after having babies Age needed to reach sexual maturity Maximum hunger allowed to reproduce" stereotype="constructor">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="ucg88kWvMqxQR" name="name, mas_hunger, ..." visibility="private" type="" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uBsSCErLOSwav" name="can_reproduce" comment="Rabbits need to be adult and not starving to reproduce Logic: Rabbits need to be mature and not too hungry.">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="u7GiR4v77Xa2V" type="uuZvRER5voAkM" direction="return"/>
        </ownedOperation>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="u8RKPAuYXl9xI" name="Koala" comment="    SPECIAL RULE: Diet specialist.&#10;    Only searches for Eucalyptus objects in the habitat.&#10;    &gt;&gt;&gt; k = Koala(&quot;Sid&quot;)&#10;    &gt;&gt;&gt; k.hunger&#10;    0.0&#10;    &gt;&gt;&gt; k.metabolic_rate&#10;    0.5&#10;    &gt;&gt;&gt; # After 2 rounds of growing without eating, hunger should be 1.0&#10;    &gt;&gt;&gt; k.grow()&#10;    &gt;&gt;&gt; k.grow()&#10;    &gt;&gt;&gt; k.hunger&#10;    1.0&#10;    &gt;&gt;&gt; k.max_hunger&#10;    8&#10;">
        <generalization xmi:type="uml:Generalization" xmi:id="uYjAcpqbpMyod" general="umsFRoR96XmpJ"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="unfKxHC1PLZph" name="__init__" stereotype="constructor">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uhrgGfSxdvbcc" name="name, max_hunger, ..." visibility="private" type="" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="ucNcSUmy8cXvV" name="eat" comment="Koala specific eating logic...">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uJEi9kUeJl8aW" type="uuZvRER5voAkM" direction="return"/>
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uNvhtLWXA2Hm1" name="habitat" visibility="private" type="u9OmGItKhHptN" value=""/>
        </ownedOperation>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="ulthyshyN5B3H" name="Bear" comment="    SPECIAL RULE: Hibernation.&#10;    Enters a state of sleep during Winter rounds where it doesn't eat.&#10;    &gt;&gt;&gt; b = Bear(&quot;Baloo&quot;)&#10;    &gt;&gt;&gt; b.hunger = 5.0&#10;    &gt;&gt;&gt; b.hibernating&#10;    False&#10;    &gt;&gt;&gt; b.prepare_hibernation(&quot;Winter&quot;) # Gehe in den Winterschlaf&#10;    &gt;&gt;&gt; b.hibernating&#10;    True&#10;    &gt;&gt;&gt; b.hunger # Hunger sollte um den hibernation_bonus (2) sinken&#10;    3.0&#10;    &gt;&gt;&gt; b.prepare_hibernation(&quot;Spring&quot;) # Wache im FrÃ¼hling auf&#10;    &gt;&gt;&gt; b.hibernating&#10;    False&#10;">
        <generalization xmi:type="uml:Generalization" xmi:id="urZGNLLOEA3AS" general="u3ZGSLOnkH7bk"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uMvtkJMnMjbL9" name="__init__" stereotype="constructor">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uPoLZRZD6bpF7" name="name, max_hunger, ..." visibility="private" type="" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="u5bDwdqSGIGki" name="prepare_hibernation">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="u0HMs1qGypX0A" name="season" visibility="private" type="uMZ6QyZIKDsho" value=""/>
        </ownedOperation>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="usEBsPATheNqK" name="Wolf">
        <generalization xmi:type="uml:Generalization" xmi:id="u15lq0JESxHJj" general="uafw02rT0a2uW"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="u9qNqmBnwTI2q" name="__init__">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uDbdGTxSaYIGZ" name="name, max_hunger, ..." visibility="private" type="" value=""/>
        </ownedOperation>
      </packagedElement>
