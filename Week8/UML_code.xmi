        <packagedElement xmi:type="uml:DataType" xmi:id="uogGX4o6I8k6n" name="unsigned short int" stereotype="dataType" isActive="false"/>
        <packagedElement xmi:type="uml:DataType" xmi:id="uulAMuurUmrUY" name="signed short int" stereotype="dataType" isActive="false"/>
        <packagedElement xmi:type="uml:DataType" xmi:id="upJySV3g7mahd" name="long int" stereotype="dataType" isActive="false"/>
        <packagedElement xmi:type="uml:DataType" xmi:id="uJBS0ZYJnHjJk" name="signed long int" stereotype="dataType" isActive="false"/>
        <packagedElement xmi:type="uml:DataType" xmi:id="uCw3RCrXhM0AR" name="unsigned long int" stereotype="dataType" isActive="false"/>
        <packagedElement xmi:type="uml:DataType" xmi:id="uTk13Bgxsev9T" name="long double" stereotype="dataType" isActive="false"/>
        <packagedElement xmi:type="uml:DataType" xmi:id="uir1mH3qfgFt3" name="wchar_t" stereotype="dataType" isActive="false"/>
        <packagedElement xmi:type="uml:DataType" xmi:id="uIGfgkLVwodcA" name="array" stereotype="dataType"/>
        <packagedElement xmi:type="uml:DataType" xmi:id="uNO6IdPYwnTMx" name="tuple" stereotype="dataType"/>
        <packagedElement xmi:type="uml:DataType" xmi:id="ux2djTHZXLuP0" name="list" stereotype="dataType"/>
        <packagedElement xmi:type="uml:DataType" xmi:id="uiU5oenAjj4HL" name="long" stereotype="dataType"/>
        <packagedElement xmi:type="uml:DataType" xmi:id="u3q76XDcpft2L" name="dict" stereotype="dataType"/>
        <packagedElement xmi:type="uml:DataType" xmi:id="uetDqfmKNig72" name="object" stereotype="dataType"/>
        <packagedElement xmi:type="uml:DataType" xmi:id="uDAg825KeYTmd" name="set" stereotype="dataType"/>
        <packagedElement xmi:type="uml:DataType" xmi:id="uMZ6QyZIKDsho" name="str" stereotype="dataType"/>
