      </uml:Package>
      <packagedElement xmi:type="uml:Class" xmi:id="u9OmGItKhHptN" name="Habitat" comment="    The habitat for the ecosystem.&#10;">
        <ownedAttribute xmi:type="uml:Property" xmi:id="uFpQLcCCUS6kx" name="used_space" comment="Initializes the habitat with a maximum capacity.&#10;&gt;&gt;&gt; h = Habitat(100)&#10;&gt;&gt;&gt; h.total_space&#10;100&#10;&gt;&gt;&gt; h.used_space&#10;0&#10;&gt;&gt;&gt; len(h.plants)&#10;0&#10;Max capacity for ground-based plants Currently occupied space List to store all plant objects List to store all animal objects Round tracker Starting season Influences growth (standard: 1.0)        Initializes the habitat with a maximum capacity.&#10;&gt;&gt;&gt; h = Habitat(100)&#10;&gt;&gt;&gt; h.total_space&#10;100&#10;&gt;&gt;&gt; h.used_space&#10;0&#10;&gt;&gt;&gt; len(h.plants)&#10;0&#10;Max capacity for ground-based plants Currently occupied space" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uPMCVBJLGCsfp" name="plants" comment="Initializes the habitat with a maximum capacity.&#10;&gt;&gt;&gt; h = Habitat(100)&#10;&gt;&gt;&gt; h.total_space&#10;100&#10;&gt;&gt;&gt; h.used_space&#10;0&#10;&gt;&gt;&gt; len(h.plants)&#10;0&#10;Max capacity for ground-based plants Currently occupied space List to store all plant objects List to store all animal objects Round tracker Starting season Influences growth (standard: 1.0)        Initializes the habitat with a maximum capacity.&#10;&gt;&gt;&gt; h = Habitat(100)&#10;&gt;&gt;&gt; h.total_space&#10;100&#10;&gt;&gt;&gt; h.used_space&#10;0&#10;&gt;&gt;&gt; len(h.plants)&#10;0&#10;Max capacity for ground-based plants Currently occupied space List to store all plant objects" type="ux2djTHZXLuP0"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uuzVxTuSN01YJ" name="animals" comment="Initializes the habitat with a maximum capacity.&#10;&gt;&gt;&gt; h = Habitat(100)&#10;&gt;&gt;&gt; h.total_space&#10;100&#10;&gt;&gt;&gt; h.used_space&#10;0&#10;&gt;&gt;&gt; len(h.plants)&#10;0&#10;Max capacity for ground-based plants Currently occupied space List to store all plant objects List to store all animal objects Round tracker Starting season Influences growth (standard: 1.0)        Initializes the habitat with a maximum capacity.&#10;&gt;&gt;&gt; h = Habitat(100)&#10;&gt;&gt;&gt; h.total_space&#10;100&#10;&gt;&gt;&gt; h.used_space&#10;0&#10;&gt;&gt;&gt; len(h.plants)&#10;0&#10;Max capacity for ground-based plants Currently occupied space List to store all plant objects List to store all animal objects" type="ux2djTHZXLuP0"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="u8njX44PGG2jZ" name="round_counter" comment="Initializes the habitat with a maximum capacity.&#10;&gt;&gt;&gt; h = Habitat(100)&#10;&gt;&gt;&gt; h.total_space&#10;100&#10;&gt;&gt;&gt; h.used_space&#10;0&#10;&gt;&gt;&gt; len(h.plants)&#10;0&#10;Max capacity for ground-based plants Currently occupied space List to store all plant objects List to store all animal objects Round tracker Starting season Influences growth (standard: 1.0)        Initializes the habitat with a maximum capacity.&#10;&gt;&gt;&gt; h = Habitat(100)&#10;&gt;&gt;&gt; h.total_space&#10;100&#10;&gt;&gt;&gt; h.used_space&#10;0&#10;&gt;&gt;&gt; len(h.plants)&#10;0&#10;Max capacity for ground-based plants Currently occupied space List to store all plant objects List to store all animal objects Round tracker" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="u9uA0U1RkQr9Y" name="season" comment="Initializes the habitat with a maximum capacity.&#10;&gt;&gt;&gt; h = Habitat(100)&#10;&gt;&gt;&gt; h.total_space&#10;100&#10;&gt;&gt;&gt; h.used_space&#10;0&#10;&gt;&gt;&gt; len(h.plants)&#10;0&#10;Max capacity for ground-based plants Currently occupied space List to store all plant objects List to store all animal objects Round tracker Starting season Influences growth (standard: 1.0)        Initializes the habitat with a maximum capacity.&#10;&gt;&gt;&gt; h = Habitat(100)&#10;&gt;&gt;&gt; h.total_space&#10;100&#10;&gt;&gt;&gt; h.used_space&#10;0&#10;&gt;&gt;&gt; len(h.plants)&#10;0&#10;Max capacity for ground-based plants Currently occupied space List to store all plant objects List to store all animal objects Round tracker Starting season" type="uMZ6QyZIKDsho"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uBpF5ntgXxSCU" name="weather_factor" comment="Initializes the habitat with a maximum capacity.&#10;&gt;&gt;&gt; h = Habitat(100)&#10;&gt;&gt;&gt; h.total_space&#10;100&#10;&gt;&gt;&gt; h.used_space&#10;0&#10;&gt;&gt;&gt; len(h.plants)&#10;0&#10;Max capacity for ground-based plants Currently occupied space List to store all plant objects List to store all animal objects Round tracker Starting season Influences growth (standard: 1.0)        Initializes the habitat with a maximum capacity.&#10;&gt;&gt;&gt; h = Habitat(100)&#10;&gt;&gt;&gt; h.total_space&#10;100&#10;&gt;&gt;&gt; h.used_space&#10;0&#10;&gt;&gt;&gt; len(h.plants)&#10;0&#10;Max capacity for ground-based plants Currently occupied space List to store all plant objects List to store all animal objects Round tracker Starting season Influences growth (standard: 1.0)" type="uB9ZTyJjsPAzA"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uXcZKLHHBXw4n" name="total_space" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uyX70wQf1d7gz" name="inhabitant" type="uEKtR2ShXotqz"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uNtFXaBW8KWiR" name="__init__" comment="Initializes the habitat with a maximum capacity.&#10;&gt;&gt;&gt; h = Habitat(100)&#10;&gt;&gt;&gt; h.total_space&#10;100&#10;&gt;&gt;&gt; h.used_space&#10;0&#10;&gt;&gt;&gt; len(h.plants)&#10;0&#10;Max capacity for ground-based plants Currently occupied space List to store all plant objects List to store all animal objects Round tracker Starting season Influences growth (standard: 1.0)" stereotype="constructor">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="usvFyKMv6wDXN" name="total_space" visibility="private" type="uyDey6iEor2tQ" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="u9kwrTSdEtejA" name="add_plant" comment="Adds a plant if space is available.&#10;&gt;&gt;&gt; h = Habitat(10)&#10;&gt;&gt;&gt; g = Grass(&quot;G1&quot;)&#10;&gt;&gt;&gt; h.add_plant(g) # Test 1: Successful add&#10;True&#10;&gt;&gt;&gt; h.used_space&#10;3&#10;&gt;&gt;&gt; h.add_plant(Grass(&quot;G2&quot;)) # Test 2: Adding more&#10;True&#10;&gt;&gt;&gt; h.add_plant(Grass(&quot;G3&quot;)) # Test 3: Fail (space: 3+3+3+3 &gt; 10)&#10;False&#10;Logic: Does the plant occupy ground space? (e.g., Grass/Trees) Check if there is enough space left in the habitat Occupy space">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uWUO6LV999Tp0" type="uuZvRER5voAkM" direction="return"/>
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uYPOqxzmkbL7g" name="plant" visibility="private" type="u2GnSq4D0yOeZ" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uulqdjTBBSHUC" name="remove_plant" comment="Removes a plant and updates used space.&#10;&gt;&gt;&gt; h = Habitat(100)&#10;&gt;&gt;&gt; g = Grass(&quot;G1&quot;)&#10;&gt;&gt;&gt; h.add_plant(g)&#10;True&#10;&gt;&gt;&gt; h.remove_plant(g) # Test 1: Successful removal&#10;&gt;&gt;&gt; len(h.plants)&#10;0&#10;&gt;&gt;&gt; h.used_space # Test 2: Space is freed&#10;0&#10;&gt;&gt;&gt; h.remove_plant(g) # Test 3: Removing non-existent (safe)&#10;If it was a ground plant, free up the space">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uWPTiDUG7eOTg" name="plant" visibility="private" type="u2GnSq4D0yOeZ" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uMrhK8gvwqI41" name="remove_animal" comment="Removes an animal from the habitat list.&#10;&gt;&gt;&gt; h = Habitat()&#10;&gt;&gt;&gt; r = Rabbit(&quot;Bugs&quot;)&#10;&gt;&gt;&gt; h.animals.append(r)&#10;&gt;&gt;&gt; len(h.animals)&#10;1&#10;&gt;&gt;&gt; h.remove_animal(r) # Test 1: Successful removal&#10;&gt;&gt;&gt; len(h.animals)&#10;0&#10;&gt;&gt;&gt; h.remove_animal(r) # Test 2: Removing non-existent (should stay 0)&#10;&gt;&gt;&gt; len(h.animals)&#10;0&#10;">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uoHjqSF7i5jS8" name="animal" visibility="private" type="uhh5q2NtgxacK" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uCV976gqoQhW3" name="change_season" comment="Rotates seasons every 10 rounds.&#10;&gt;&gt;&gt; h = Habitat()&#10;&gt;&gt;&gt; h.round_counter = 10&#10;&gt;&gt;&gt; h.change_season() # Test 1: Switches to Summer&#10;&gt;&gt;&gt; h.season&#10;'Summer'&#10;&gt;&gt;&gt; h.round_counter = 20&#10;&gt;&gt;&gt; h.change_season() # Test 2: Switches to Autumn&#10;&gt;&gt;&gt; h.season&#10;'Autumn'&#10;&gt;&gt;&gt; h.weather_factor # Test 3: Factor updated&#10;0.9&#10;Modulo check: Every 10 rounds, move to the next season SPECIAL RULE: Weather influence on plant growth"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="usLVAo0wALgqo" name="check_space_competition" comment="SPECIAL RULE: Smallest plants die if habitat is over 90% full.&#10;Naturtural selection due to space competition.&#10;&gt;&gt;&gt; h = Habitat(10)&#10;&gt;&gt;&gt; h.add_plant(Grass(&quot;G1&quot;))&#10;True&#10;&gt;&gt;&gt; h.add_plant(Grass(&quot;G2&quot;))&#10;True&#10;&gt;&gt;&gt; h.add_plant(Grass(&quot;G3&quot;)) # Total 9 space (90%)&#10;True&#10;&gt;&gt;&gt; h.check_space_competition() # Test 1: Safe&#10;&gt;&gt;&gt; len(h.plants)&#10;3&#10;&gt;&gt;&gt; h.total_space = 9 # Now 9 is 100% capacity&#10;&gt;&gt;&gt; h.check_space_competition() # Test 2: Competition starts&#10;&gt;&gt;&gt; len(h.plants) &lt; 3&#10;True&#10;&gt;&gt;&gt; h.used_space &lt; 9 # Test 3: Space freed&#10;True&#10;If more than 90% of the space is occupied Sort by size: The smallest/weakest die first Remove 10% of the plant population"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="u4aFGsDVVsHNw" name="simulate_round" comment="The core loop of the simulation. Executes one round of growth,&#10;eating, reproduction, and death for all plants and animals.&#10;&gt;&gt;&gt; h = Habitat(100)&#10;&gt;&gt;&gt; r = Rabbit(&quot;Shorty&quot;)&#10;&gt;&gt;&gt; h.add_animal(r)&#10;&gt;&gt;&gt; # Force the rabbit to be near death&#10;&gt;&gt;&gt; r.hunger = 5.9&#10;&gt;&gt;&gt; r.max_hunger = 6.0&#10;&gt;&gt;&gt;&#10;&gt;&gt;&gt; # After one round, metabolic rate (1.0) is added&#10;&gt;&gt;&gt; h.simulate_round()&#10;&gt;&gt;&gt;&#10;&gt;&gt;&gt; # The rabbit should have died and been removed&#10;&gt;&gt;&gt; len(h.animals)&#10;0&#10;Increment round and update environment PHASE 1: PLANTS We use [:] to iterate over a copy so we can safely remove dead plants Capture return value: Can be actual_growth (int), an Apple object, or None Check if a Tree produced an Apple Standard plant reproduction logic (20% chance) PHASE 2: ANIMALS SPECIAL RULE: Bear hibernation check Animal ages/grows Animal searches for food Reproduction check Check for starvation Remove animals that were killed (e.g. eaten or natural death)"/>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="uEKtR2ShXotqz" name="LivingBeing" isAbstract="true" comment="    Abstract base class for every entity in the ecosystem.&#10;    The purpose of this class is to provide a unified interface&#10;    for all living objects. Methods such as 'grow' and 'get_info'&#10;    are defined as abstract because plants and animals differ&#10;    fundamentally in their growth and reporting logic.&#10;    Using an abstract base class enforces specific implementations&#10;    in subclasses and prevents the instantiation of generic,&#10;    non-functional 'LivingBeing' objects.&#10;    &gt;&gt;&gt; # This test proves that you cannot create a generic LivingBeing:&#10;    &gt;&gt;&gt; try:&#10;    ...     lb = LivingBeing(&quot;Mystery&quot;)&#10;    ... except TypeError:&#10;    ...     print(&quot;Caught expected error: Cannot instantiate ABC&quot;)&#10;    Caught expected error: Cannot instantiate ABC&#10;">
        <generalization xmi:type="uml:Generalization" xmi:id="uK6zRROb5bp5m" general="u9PoKwRynJ92p"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uFmkRjYB3QNPi" name="name" type="uMZ6QyZIKDsho"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uf3OGVFk2ixAk" name="age" comment="Basic attributes shared by plants and animals Basic attributes shared by plants and animals" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="urgluXvWtj8xv" name="is_alive" comment="Basic attributes shared by plants and animals Basic attributes shared by plants and animals" type="uuZvRER5voAkM"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uNptNnXAOb25M" name="__init__" comment="Basic attributes shared by plants and animals" stereotype="constructor">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uBl3vTe5ugyxu" name="name" visibility="private" type="uMZ6QyZIKDsho" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uGwOyFMSDn1T2" name="grow" isAbstract="true" comment="Must be implemented by subclasses to handle aging/growth."/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="umxYh4orZhsvK" name="die" comment="Sets the status to dead. Dead objects are removed by the Habitat."/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="u76hGoDbf6Ap0" name="get_info" comment="Returns a string representation of the object's status."/>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="u2GnSq4D0yOeZ" name="Plant" isAbstract="true" comment="    Base class for all vegetation.&#10;     &gt;&gt;&gt; p = Plant(&quot;TestPlant&quot;, min_size=5, max_size=20, growth_rate=2)&#10;     &gt;&gt;&gt; p.current_size&#10;    5&#10;    &gt;&gt;&gt; p.be_eaten(2)&#10;    True&#10;    &gt;&gt;&gt; p.current_size&#10;    3&#10;    &gt;&gt;&gt; p.be_eaten(5)&#10;    False&#10;    &gt;&gt;&gt; p.is_alive&#10;    False&#10;">
        <generalization xmi:type="uml:Generalization" xmi:id="uin6nSMwbww0T" general="uEKtR2ShXotqz"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="u4NThrAgYbgTC" name="min_size" comment="Used for habitat capacity logic Distinguishes ground plants from epiphytes Default lifespan for plants" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="ux1j38fZ6yQQ3" name="max_size" comment="Used for habitat capacity logic Distinguishes ground plants from epiphytes Default lifespan for plants" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uk8No7imfLHYk" name="current_size" comment="Used for habitat capacity logic Distinguishes ground plants from epiphytes Default lifespan for plants" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uv2PWNS0h2uwg" name="growth_rate" comment="Used for habitat capacity logic Distinguishes ground plants from epiphytes Default lifespan for plants" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uWPNmecgMOYrh" name="space_needed" comment="Used for habitat capacity logic Distinguishes ground plants from epiphytes Default lifespan for plants Used for habitat capacity logic" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uat0sYCpAVkf7" name="needs_ground" comment="Used for habitat capacity logic Distinguishes ground plants from epiphytes Default lifespan for plants Used for habitat capacity logic Distinguishes ground plants from epiphytes" type="uuZvRER5voAkM"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="u3oLrUxmA9EeL" name="reproduction_interval" comment="Used for habitat capacity logic Distinguishes ground plants from epiphytes Default lifespan for plants Used for habitat capacity logic Distinguishes ground plants from epiphytes" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uo7BvFrrzz4Hh" name="rounds_since_reproduction" comment="Used for habitat capacity logic Distinguishes ground plants from epiphytes Default lifespan for plants Used for habitat capacity logic Distinguishes ground plants from epiphytes" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uMGSgEiNUWXqj" name="max_age" comment="Used for habitat capacity logic Distinguishes ground plants from epiphytes Default lifespan for plants Used for habitat capacity logic Distinguishes ground plants from epiphytes Default lifespan for plants" type="uyDey6iEor2tQ"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uHnoShQnhke5Y" name="__init__" comment="Used for habitat capacity logic Distinguishes ground plants from epiphytes Default lifespan for plants" stereotype="constructor">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uWc7QdlkV7DFG" name="name, min_size, ..." visibility="private" type="" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uR9FOxtempmQD" name="grow" comment="Increases size based on growth rate and environmental factors.&#10;RANDOMIZED ASPECT: Growth varies slightly every round (0.7 to 1.3 multiplier) Ensure the plant doesn't exceed its maximum natural size Plants age every time they grow">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uedYGf2Nr89U6" type="uyDey6iEor2tQ" direction="return"/>
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uu8Yvybm2e0Ga" name="weather_factor" visibility="private" type="uB9ZTyJjsPAzA" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uqaQlJKCpNhZC" name="be_eaten" comment="Reduces size when an animal grazes on the plant.&#10;If size drops below minimum, the plant dies.&#10;Plant died Plant survived">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uPGhKb1HquAqv" type="uuZvRER5voAkM" direction="return"/>
          <ownedParameter xmi:type="uml:Parameter" xmi:id="ukjcQT2d0kFDz" name="amount" visibility="private" type="uyDey6iEor2tQ" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uPrZbipBbF9fx" name="can_reproduce" comment="Logic for plant spreading. Requires enough size and a cooldown period.&#10;Cooldown check to prevent exponential overgrowth Plant must be mature (80% of max size) to reproduce Reset cooldown">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="utNyI43hZwHVB" type="uuZvRER5voAkM" direction="return"/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="u3LJaIGwaYL4b" name="get_info" comment="--- Specialized Plant Classes ---">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uKqljaU8lpg6x" type="uMZ6QyZIKDsho" direction="return"/>
        </ownedOperation>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="u2B9E0tWKf4OY" name="Tree" comment="    Trees grow large and slowly.&#10;    SPECIAL RULE: They provide Apples for Rabbits and Bears.&#10;    &gt;&gt;&gt; # Testing initialization&#10;    &gt;&gt;&gt; t = Tree(&quot;Appletree_1&quot;)&#10;    &gt;&gt;&gt; t.current_size&#10;    20&#10;    &gt;&gt;&gt; t.space_needed # Trees occupy ground space based on size&#10;    20&#10;    &gt;&gt;&gt; # Test growth with weather factor 1.0&#10;    &gt;&gt;&gt; # Growth rate for Tree is 2&#10;    &gt;&gt;&gt; _ = t.grow(1.0)&#10;    &gt;&gt;&gt; t.current_size&#10;    22&#10;    &gt;&gt;&gt; # Test reproduction check (cooldown is 5 rounds)&#10;    &gt;&gt;&gt; t.can_reproduce()&#10;    False&#10;">
        <generalization xmi:type="uml:Generalization" xmi:id="uE39Ptxu5SlWu" general="u2GnSq4D0yOeZ"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uBemO329PIY93" name="__init__" stereotype="constructor">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uDADemhD2grmr" name="name, min_size, ..." visibility="private" type="" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="unH9d5LiMsc2U" name="grow">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="u4bIMPy51PNtr" name="weather_factor" visibility="private" type="uB9ZTyJjsPAzA" value=""/>
        </ownedOperation>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="uqCa5jvocWHC6" name="Grass" comment="    Grass grows fast but stays small.&#10;    SPECIAL RULE: High drought resistance helps it survive bad weather.&#10;    &gt;&gt;&gt; # Testing initialization and space usage&#10;    &gt;&gt;&gt; g = Grass(&quot;Meadow_1&quot;)&#10;    &gt;&gt;&gt; g.current_size&#10;    2&#10;    &gt;&gt;&gt; g.space_needed # Size 2 = Space 2&#10;    2&#10;    &gt;&gt;&gt; # Test growth with weather factor 1.0&#10;    &gt;&gt;&gt; # Growth rate for Grass is 3&#10;    &gt;&gt;&gt; _ = g.grow(1.0)&#10;    &gt;&gt;&gt; g.current_size&#10;    5&#10;    &gt;&gt;&gt; g.be_eaten(4) # Rabbit eats 4 units&#10;    True&#10;    &gt;&gt;&gt; g.current_size&#10;    1&#10;">
        <generalization xmi:type="uml:Generalization" xmi:id="unCjF8Wc9CEZJ" general="u2GnSq4D0yOeZ"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uhrsD38Ac2O4l" name="__init__" stereotype="constructor">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uEBx1TA7h1EZu" name="name, min_size, ..." visibility="private" type="" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="uIy8pjtDiZcwX" name="grow">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uMu3uT9zpCQTK" name="weather_factor" visibility="private" type="uB9ZTyJjsPAzA" value=""/>
        </ownedOperation>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="uExQ5lH4NW6YW" name="Eucalyptus" comment="    SPECIAL RULE: Toxic to most, only Koalas can eat this.&#10;    &gt;&gt;&gt; # Testing initialization and growth&#10;    &gt;&gt;&gt; e = Eucalyptus(&quot;Euca_1&quot;)&#10;    &gt;&gt;&gt; e.current_size&#10;    10&#10;    &gt;&gt;&gt; e.space_needed&#10;    10&#10;    &gt;&gt;&gt; # Test growth with a standard weather factor of 1.0&#10;    &gt;&gt;&gt; _ = e.grow(1.0)&#10;    &gt;&gt;&gt; e.current_size # Should increase by growth_rate (2)&#10;    12&#10;    &gt;&gt;&gt; e.be_eaten(5) # Koala eats 5 units&#10;    True&#10;    &gt;&gt;&gt; e.current_size&#10;    7&#10;">
        <generalization xmi:type="uml:Generalization" xmi:id="ubHnO1nZchVUp" general="u2GnSq4D0yOeZ"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="ujChJ6njNlk3j" name="__init__" stereotype="constructor">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uWGopBJ5gnP6I" name="name, min_size, ..." visibility="private" type="" value=""/>
        </ownedOperation>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="uTQRbTahUVYoW" name="Apple" comment="    Represents a fruit dropped by a Tree.&#10;    Does not grow or reproduce,&#10;    but serves as a temporary food source on the ground.&#10;    &gt;&gt;&gt; a = Apple()&#10;    &gt;&gt;&gt; a.current_size&#10;    5&#10;    &gt;&gt;&gt; a.space_needed&#10;    0&#10;    &gt;&gt;&gt; a.age&#10;    1&#10;">
        <generalization xmi:type="uml:Generalization" xmi:id="uv3VZV41G0YSa" general="u2GnSq4D0yOeZ"/>
        <ownedOperation xmi:type="uml:Operation" xmi:id="u7pTY8R5EYbQl" name="__init__" comment="growth_rate=0: Apples do not increase in size once fallen space_needed=0: Essential so that fruit doesn't block tree growth reproduction_interval=999: Apples cannot create more apples Lifespan in rounds before the apple rots" stereotype="constructor">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="uOYYyFfJIcaSb" name="name, min_size, ..." visibility="private" type="" value=""/>
        </ownedOperation>
        <ownedOperation xmi:type="uml:Operation" xmi:id="umhLaayEephtR" name="grow">
          <ownedParameter xmi:type="uml:Parameter" xmi:id="u3kfnjZrt7cCE" name="weather_factor" visibility="private" type="uB9ZTyJjsPAzA" value=""/>
        </ownedOperation>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="uhh5q2NtgxacK" name="Animal" isAbstract="true" comment="    Abstract base class for all mobile creatures.&#10;    &gt;&gt;&gt; a = Rabbit(&quot;TestBunny&quot;)&#10;    &gt;&gt;&gt; a.hunger # Startet satt&#10;    0.0&#10;    &gt;&gt;&gt; a.metabolic_rate # Intervall 1 -&gt; 1.0 Hunger pro Runde&#10;    1.0&#10;    &gt;&gt;&gt; a.grow()&#10;    &gt;&gt;&gt; a.hunger&#10;    1.0&#10;">
        <generalization xmi:type="uml:Generalization" xmi:id="uQGQuH3A8eMCw" general="uEKtR2ShXotqz"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uXihK8zijVv3m" name="hunger" comment="Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round Logic: Named constant for metabolic energy saved during hibernation. This makes it easy to adjust the survival bonus in one central place. Reproduction attributes Current timer (starts at 0) Rounds to wait after having a baby Age needed to be mature enough Maximum hunger allowed to reproduce" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uJpqQylmyg2b3" name="max_hunger" comment="Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round Logic: Named constant for metabolic energy saved during hibernation. This makes it easy to adjust the survival bonus in one central place. Reproduction attributes Current timer (starts at 0) Rounds to wait after having a baby Age needed to be mature enough Maximum hunger allowed to reproduce Death occurs if hunger reaches this" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="ua8gtZEeSLFas" name="strength" comment="Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round Logic: Named constant for metabolic energy saved during hibernation. This makes it easy to adjust the survival bonus in one central place. Reproduction attributes Current timer (starts at 0) Rounds to wait after having a baby Age needed to be mature enough Maximum hunger allowed to reproduce Death occurs if hunger reaches this Used for hunting success or defense" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="upTNslNOVazpT" name="hibernating" comment="Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round Logic: Named constant for metabolic energy saved during hibernation. This makes it easy to adjust the survival bonus in one central place. Reproduction attributes Current timer (starts at 0) Rounds to wait after having a baby Age needed to be mature enough Maximum hunger allowed to reproduce Death occurs if hunger reaches this Used for hunting success or defense" type="uuZvRER5voAkM"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uOgg0L5QYLCpW" name="feeding_interval" comment="Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round Logic: Named constant for metabolic energy saved during hibernation. This makes it easy to adjust the survival bonus in one central place. Reproduction attributes Current timer (starts at 0) Rounds to wait after having a baby Age needed to be mature enough Maximum hunger allowed to reproduce Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uxXm0Ti1pYGd2" name="rounds_since_eating" comment="Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round Logic: Named constant for metabolic energy saved during hibernation. This makes it easy to adjust the survival bonus in one central place. Reproduction attributes Current timer (starts at 0) Rounds to wait after having a baby Age needed to be mature enough Maximum hunger allowed to reproduce Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uzDzQMQdRAdKw" name="max_age" comment="Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round Logic: Named constant for metabolic energy saved during hibernation. This makes it easy to adjust the survival bonus in one central place. Reproduction attributes Current timer (starts at 0) Rounds to wait after having a baby Age needed to be mature enough Maximum hunger allowed to reproduce Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals" type="uyDey6iEor2tQ"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="uo7NxGb22C0H4" name="metabolic_rate" comment="Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round Logic: Named constant for metabolic energy saved during hibernation. This makes it easy to adjust the survival bonus in one central place. Reproduction attributes Current timer (starts at 0) Rounds to wait after having a baby Age needed to be mature enough Maximum hunger allowed to reproduce Death occurs if hunger reaches this Used for hunting success or defense Rounds between meals Default lifespan for animals LOGIC: Instead of fixed hunger values, we calculate a rate. This eliminates 'Magic Numbers' and makes the simulation scalable. Interval 1 (small animals) = 1.0 hunger/round Interval 2 (medium animals) = 0.5 hunger/round Interval 3 (large animals) = 0.33 hunger/round" type="uB9ZTyJjsPAzA"/>
